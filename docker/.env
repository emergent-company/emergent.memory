# =============================================================================
# LOCAL DOCKER BOOTSTRAP DEFAULTS — SAFE PLACEHOLDER VALUES
# =============================================================================
#
# This file contains PLACEHOLDER values only. Real credentials must be
# supplied via docker/.env.local (gitignored, not tracked).
#
# To set up local development with real credentials:
#   cp docker/.env.local.example docker/.env.local   (if example exists)
#   — OR — create docker/.env.local manually with real values
#
# Variables that MUST be overridden in docker/.env.local for a working stack:
#   ZITADEL_API_KEY         — service account RSA private key JSON
#   ZITADEL_CLIENT_JWT      — service account RSA private key JSON
#   ZITADEL_PAT             — personal access token
#   ZITADEL_MASTERKEY       — exactly 32 characters
#   ZITADEL_FIRSTINSTANCE_ORG_HUMAN_PASSWORD
#
# For local development fallback (when Infisical unavailable):
#   ./scripts/env-export.sh --env local --path /docker --overwrite
#
# =============================================================================

ZITADEL_API_CLIENT_ID='348019532759040003'

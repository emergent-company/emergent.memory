{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/claude-opus-4.6",
  // Use a fast, cheap model for automatic session title generation
  "small_model": "github-copilot/gpt-5-mini",
  "theme": "tokyonight",
  // Keybinds for session management
  "keybinds": {
    "session_rename": "ctrl+r",
    "session_list": "ctrl+x l"
  },
  "snapshot": false,
  "mcp": {
    // "figma": {
    //   "type": "remote",
    //   "url": "http://127.0.0.1:3845/mcp"
    // },
    // "playwright": {
    //   "type": "local",
    //   "command": [
    //     "npx",
    //     "@playwright/mcp@latest",
    //     "--timeout-action=10000"
    //   ]
    // },
    "postgres": {
      "type": "local",
      "command": ["./scripts/mcp-postgres-wrapper.sh"],
      "timeout": 60000
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "timeout": 60000
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--browserUrl",
        "http://100.75.227.125:9222"
      ],
      "timeout": 120000
    }
  },
  "instructions": [
    "apps/server/docs/agent-context/infrastructure.md",
    "apps/server/docs/agent-context/e2e-testing.md"
  ],
  "tools": {
    "todowrite": true,
    "webfetch": true
  }
}
